<Project>
  <PropertyGroup>
    <!-- Override the detected OS if needed: windows, linux, macos -->
    <!-- <Sts2Os>linux</Sts2Os> -->

    <!-- Path to Slay the Spire 2 installation -->
    <!-- Windows: -->
    <STS2GamePath>C:/Program Files (x86)/Steam/steamapps/common/Slay the Spire 2</STS2GamePath>
    <!-- Linux: -->
    <!-- <STS2GamePath>~/.steam/steam/steamapps/common/Slay the Spire 2</STS2GamePath> -->
    <!-- macOS: -->
    <!-- <STS2GamePath>~/Library/Application Support/Steam/steamapps/common/Slay the Spire 2</STS2GamePath> -->

    <!-- Path to game data folder containing DLLs -->
    <!-- Windows: -->
    <GameDataDir>$(STS2GamePath)/data_sts2_windows_x86_64</GameDataDir>
    <!-- Linux: -->
    <!-- <GameDataDir>$(STS2GamePath)/data_sts2_linux_x86_64</GameDataDir> -->
    <!-- macOS: -->
    <!-- <GameDataDir>$(STS2GamePath)/SlayTheSpire2.app/Contents/Resources/data_sts2_macos_universal</GameDataDir> -->

    <!-- Path to MegaDot executable -->
    <MegaDotExe>YOUR_MEGADOT_PATH/MegaDot_v4.5.1-stable_mono_win64.exe</MegaDotExe>

    <!-- Mod folder name -->
    <ModName>sts2mcp</ModName>
  </PropertyGroup>
</Project>
